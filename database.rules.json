{
    "rules": {
        "queue": {
            ".read": true,
            ".write": true
        },
        "chats": {
            ".read": true,
            ".write": true,
            "$chatId": {
                "messages": {
                    ".indexOn": [
                        "timestamp"
                    ]
                }
            }
        },
        "messages": {
            ".read": true,
            ".write": true
        },
        "activeChats": {
            ".read": true,
            ".write": true
        },
        "reports": {
            ".read": "auth != null",
            ".write": true,
            ".indexOn": ["status", "reportedUser"]
        },
        "stats": {
            ".read": true,
            ".write": true
        },
        "favorites": {
            ".read": true,
            ".write": true
        },
        "feedback": {
            ".read": false,
            ".write": true
        },
        "users": {
            ".read": true,
            ".write": true
        },
        "reconnectRequests": {
            ".read": true,
            ".write": true
        },
        "friendRooms": {
            ".read": true,
            ".write": true
        },
        "moderationLogs": {
            ".read": false,
            ".write": true
        },
        "bannedSessions": {
            "$userId": {
                ".read": true,
                ".write": "!data.exists() && newData.exists() && newData.child('reason').val() === 'under-18'"
            }
        },
        "verificationLogs": {
            "$userId": {
                ".read": "auth != null",
                ".write": "newData.child('verified').val() === true && root.child('ageVerificationRequests/' + $userId).exists()"
            }
        },
        "ageVerificationRequests": {
            "$userId": {
                ".read": true,
                ".write": "newData.child('birthdateTimestamp').val() <= now - 567648000000"
            }
        },
        "banned_identifiers": {
            "$userId": {
                ".read": true,
                ".write": "auth != null"
            }
        },
        "warnings": {
            "$userId": {
                ".read": true,
                ".write": "auth != null"
            }
        }
    }
}
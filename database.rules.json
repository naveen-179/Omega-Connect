{
    "rules": {
        "queue": {
            ".read": true,
            ".write": true
        },
        "chats": {
            ".read": true,
            ".write": true,
            "$chatId": {
                "messages": {
                    ".indexOn": [
                        "timestamp"
                    ]
                }
            }
        },
        "activeChats": {
            ".read": true,
            ".write": true
        },
        "reports": {
            ".read": false,
            ".write": true
        },
        "stats": {
            ".read": true,
            ".write": true
        },
        "favorites": {
            ".read": true,
            ".write": true
        },
        "feedback": {
            ".read": false,
            ".write": true
        }
    }
}
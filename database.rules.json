{
    "rules": {
        "queue": {
            ".read": true,
            ".write": true
        },
        "chats": {
            ".read": true,
            ".write": true,
            "$chatId": {
                "messages": {
                    ".indexOn": [
                        "timestamp"
                    ]
                }
            }
        },
        "messages": {
            ".read": true,
            ".write": true
        },
        "activeChats": {
            ".read": true,
            ".write": true
        },
        "reports": {
            ".read": "auth != null",
            ".write": true,
            ".indexOn": ["status", "reportedUser"]
        },
        "stats": {
            ".read": true,
            ".write": true
        },
        "favorites": {
            ".read": true,
            ".write": true
        },
        "feedback": {
            ".read": false,
            ".write": true
        },
        "users": {
            ".read": true,
            ".write": true
        },
        "reconnectRequests": {
            ".read": true,
            ".write": true
        },
        "friendRooms": {
            ".read": true,
            ".write": true
        },
        "moderationLogs": {
            ".read": false,
            ".write": true
        },
        "bannedSessions": {
            ".read": false,
            ".write": false
        },
        "verificationLogs": {
            ".read": false,
            ".write": false
        },
        "bannedUsers": {
            "$userId": {
                ".read": true,
                ".write": "auth != null"
            }
        },
        "warnings": {
            "$userId": {
                ".read": true,
                ".write": "auth != null"
            }
        }
    }
}